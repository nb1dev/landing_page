# ============================================================
# ENVIRONMENT LOCAL - Copiaza acest fisier in .env si completeaza
# ============================================================
# ATENTIE: Nu conecta niciodata local la DATABASE_URL din STG sau PROD!

# Local PostgreSQL (pornit cu: docker compose up -d)
DATABASE_URL=postgresql://payload:payload@localhost:5432/landing_page_local

# Genereaza un secret random: openssl rand -hex 32
PAYLOAD_SECRET=dev_secret_schimba_asta

# Local dev
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Nu sunt necesare in local
CRON_SECRET=dev_cron_secret
PREVIEW_SECRET=dev_preview_secret

# SMTP local (optional - pentru email dev poti folosi Mailpit sau Mailtrap)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=dev@localhost.com
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost.com

# Chatwoot (optional in local)
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=
NEXT_PUBLIC_CHATWOOT_BASE_URL=
